   "source": [
    "import os\n",
    "from helper import process_data\n",
    "from google.cloud import storage"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Parameters\n",
    "INPUT_FILE = 'sample_data.txt'\n",
    "BUCKET_NAME = 'testing-depl',
    "OUTPUT_BLOB_NAME = 'output/processed_data.txt'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def main_notebook_logic(input_path, bucket_name, output_path):\n",
    "    \"\"\"Reads data, processes it, and writes to GCS.\"\"\"\n",
    "    print(f\"Reading from: {input_path}\")\n",
    "    with open(input_path, 'r') as f:\n",
    "        lines = f.readlines()\n",
    "    \n",
    "    print(f\"Processing {len(lines)} lines...\")\n",
    "    processed_lines = process_data(lines)\n",
    "    output_content = \"\\n\".join(processed_lines)\n",
    "    \n",
    "    print(f\"Writing output to gs://{bucket_name}/{output_path}\")\n",
    "    try:\n",
    "        client = storage.Client()\n",
    "        bucket = client.bucket(bucket_name)\n",
    "        blob = bucket.blob(output_path)\n",
    "        blob.upload_from_string(output_content)\n",
    "        print(\"Write to GCS successful!\")\n",
    "    except Exception as e:\n",
    "        print(f\"Error writing to GCS: {e}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Execute the main logic\n",
    "if __name__ == '__main__':\n",
    "    main_notebook_logic(INPUT_FILE, BUCKET_NAME, OUTPUT_BLOB_NAME)"
   ]
  }
 ],
